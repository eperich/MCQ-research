def make_java_out_str(output_str, num_vars):
    output_str_split = [string for string in output_str.split('{}') if string]

    out_str = 'System.out.println('
    if num_vars == 3: # Two output statements
        out_str = 'System.out.print("{}");\n\t\tSystem.out.println('.format(output_str_split[0])
        out_str += '{} + '
        output_str_split.pop(0)

    if output_str.index('{}') == 0: # Output starts with a variable
        out_str += '{} + '

    for i, string in enumerate(output_str_split):
        out_str += '"{}"'.format(string) # String literal
        if i != len(output_str_split) - 1:
            out_str += ' + {} + ' # String variable

    if output_str.rindex('{}') == len(output_str) - 2: # Output ends with a variable
        out_str += ' + {}'

    out_str += ');'

