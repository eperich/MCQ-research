   private String removeComments(String data) {
      // Recommended by Google&apos;s AI assisted search
      data = data.replaceAll(&quot;(?s)/\\*.*?\\*/&quot;, &quot;&quot;); // multiline comment
      data = data.replaceAll(&quot;//.*&quot;, &quot;&quot;);  // single-line comment
      return data;
   }
   private String removeWhitespaces(String data) {
      data = data.replaceAll(&quot;\\s+&quot;, &quot; &quot;);
      return data;
   }
   private String removeMultiSemicolons(String data) {
      data = data.replaceAll(&quot;;\\s*;*&quot;, &quot;;&quot;);
      return data;
   }
   
   void run() {
      // Check for keywords afterwards
      try {
         String data = new String(Files.readAllBytes(Paths.get(path)), StandardCharsets.UTF_8);
         int startIndex = data.indexOf(startMarker) + startMarker.length();
         int endIndex = data.indexOf(endMarker);
         String answer = data.substring(startIndex, endIndex);
         answer = removeComments(answer).trim();
         answer = removeWhitespaces(answer);
         answer = removeMultiSemicolons(answer);
         boolean isOK = true;


         if (DEBUG) {
            System.out.println(answer);
         }




         Boolean sameType = type1.equals(type2);
         
         // Step 1: check type
         {
            int numDeclarations = answer.split(&quot;;&quot;, -1).length - 1; // Ex: 2 declarations means 2 semicolons which gives 3 fields
         
            // Two types, or same type but two separate declarations
            if (!sameType || (sameType &amp;&amp; numDeclarations==2)) {
               if (!answer.contains(type1 + &quot; &quot; + var1)) {
                  System.out.println(var1 + &quot; not &quot; + type1);
                  isOK = false;
               }
               if (!answer.contains(type2 + &quot; &quot; + var2)) {
                  System.out.println(var2 + &quot; not &quot; + type2);
                  isOK = false;
               }
            }
            // One type one declaration. Ex: final double var1=1, var2=2;
            else if (sameType &amp;&amp; numDeclarations==1) {
               if (!answer.contains(type1 + &quot; &quot; + var1) &amp;&amp; !answer.contains(type1 + &quot; &quot; + var2)) {
                  System.out.println(var1 + &quot; and &quot; + var2 + &quot; not &quot; + type1);
                  isOK = false;
               }
            }
            else {
               System.out.println(&quot;Two final variable declarations expected&quot;);
               isOK = false;
            }
         }
         if (!isOK) return;


         // Step 2: check final
         {
            int numDeclarations = answer.split(type1, -1).length - 1;
            String[] tokens = answer.split(&quot;final&quot;, -1);
            int occurrences = tokens.length - 1;
            // final not found
            if (occurrences == 0) {
               System.out.println(&quot;Both &quot; + var1 + &quot; and &quot; + var2 + &quot; not final&quot;);
               isOK = false;
            }
            // one final cannot be shared by two different types or two separate declarations
            else if (occurrences == 1 &amp;&amp; (!sameType || (sameType &amp;&amp; numDeclarations==2))) {
               // var1 appears before final
               if (tokens[0].contains(var1)) {
                  System.out.println(var1 + &quot; not final&quot;);
                  isOK = false;
               }
               // var2 appears before final
               else if (tokens[0].contains(var2)) {
                  System.out.println(var2 + &quot; not final&quot;);
                  isOK = false;
               }
               // final applies to var1 but not var2
               else if (tokens[1].indexOf(var1) &lt; tokens[1].indexOf(var2)) {
                  System.out.println(var2 + &quot; not final&quot;);
                  isOK = false;
               }
               // final applies to var2 but not var1
               else if (tokens[1].indexOf(var2) &lt; tokens[1].indexOf(var1)) {
                  System.out.println(var1 + &quot; not final&quot;);
                  isOK = false;
               }
            }
         }
         if (!isOK) return;
      } catch (Exception e) {
         if (DEBUG) {
            System.err.println(&quot;Error &quot; + e.getMessage());
         }
      }
   }


