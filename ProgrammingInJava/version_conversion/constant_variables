public class Driver {
   String className = &quot;${distractor.class_name}.java&quot;;
   String type1 = &quot;${distractor.constant1_dtype}&quot;;
   String type2 = &quot;${distractor.constant2_dtype}&quot;;
   String var1 = &quot;${distractor.constant1_name}&quot;;
