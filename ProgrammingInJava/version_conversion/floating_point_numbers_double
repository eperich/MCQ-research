exception_dict = {&apos;foot&apos;: &apos;feet&apos;, &apos;inch&apos;: &apos;inches&apos;}


def singular_plural(singular):
    plural = &apos;{}s&apos;.format(singular)
    
    if singular in exception_dict.keys():
        plural = exception_dict[singular]
    elif singular[-1] == &apos;s&apos;:
        plural = singular
    
    return plural


def add_s(digit):
    return &apos;&apos; if digit == 1 else &apos;s&apos;


def float_string(real_num, precision):
    fstr = &apos;{:.{}f}&apos;.format(precision)
    return fstr.format(float(real_num))


def solve(str_term_list, variable, value): # -ax^2 -bx -c
    float_term_list = [1.0] * len(str_term_list)

    for i in range(len(str_term_list)):
        if str_term_list[i].startswith(&apos;-&apos;): # -ax^2
            float_term_list[i] *= -1.0
            str_term_list[i] = str_term_list[i][1 :] # ax^2
        
        var_index = str_term_list[i].find(variable)
        if var_index != -1:
            var_str = str_term_list[i][var_index :] # x
            exp_str = var_str.find(&apos;^&apos;)
            
            exp_int = 1
            if exp_str != -1: # x^2
                exp_int = int(var_str[exp_str + 1 :]) # 2
            
            float_term_list[i] *= (value ** exp_int)
            
            str_term_list[i] = str_term_list[i][: var_index] # a
        
        if str_term_list[i]: # If there is a constant
            float_term_list[i] *= float(str_term_list[i])

    return sum(float_term_list)


def make_polynomial():
    poly_val_str_list = [&apos;{:.1f}&apos;.format(integer / 2.0) for integer in range(1, 21)]
    value1_str, value3_str = random.sample(poly_val_str_list, 2)
    value2_str = pick_from(poly_val_str_list+[&apos;0.0&apos;], [value1_str, value3_str])
    
    term1_op = pick_from([&apos;&apos;, &apos;-&apos;])
    term2_op = pick_from([&apos;+&apos;, &apos;-&apos;])
    term3_op = pick_from([&apos;+&apos;, &apos;-&apos;])
    
    ivar = pick_from([&apos;c&apos;, &apos;e&apos;, &apos;m&apos;, &apos;n&apos;, &apos;s&apos;, &apos;u&apos;, &apos;v&apos;, &apos;w&apos;, &apos;x&apos;])
    dvar = pick_from([&apos;g&apos;, &apos;h&apos;, &apos;k&apos;, &apos;p&apos;, &apos;q&apos;, &apos;t&apos;])
    
    term1 = &apos;{}{}^2&apos;.format(value1_str, ivar) # ax^2
    rhs_term1 = &apos;({0} * {1} * {1})&apos;.format(value1_str, ivar) # a * x * x
    
    if value1_str == &apos;1.0&apos;: # a == 1
        term1 = &apos;{}^2&apos;.format(ivar) # x^2
        rhs_term1 = &apos;({0} * {0})&apos;.format(ivar) # x * x
    
    if term1_op:
        term1 = &apos;{}{}&apos;.format(term1_op, term1) # -ax^2 or -x^2
        rhs_term1 = &apos;{}{}&apos;.format(term1_op, rhs_term1) # -a * x * x or -x * x
    
    term2 = &apos;{}{}&apos;.format(value2_str, ivar) # bx
    rhs_term2 = &apos;({} * {})&apos;.format(value2_str, ivar) # b * x
    if value2_str == &apos;1.0&apos;: # b == 1
        term2 = &apos;{}&apos;.format(ivar) # x
        rhs_term2 = term2 # x
    
    rhs_term2 = &apos;{} {}&apos;.format(term2_op, rhs_term2) # +/- b * x or +/- x
    if term2_op == &apos;-&apos;:
        term2 = &apos;{}{}&apos;.format(term2_op, term2) # -bx or -x
    
    rhs_term3 = &apos;{} {}&apos;.format(term3_op, value3_str) # +/- c
    term3 = value3_str # c
    if term3_op == &apos;-&apos;:
        term3 = &apos;{}{}&apos;.format(term3_op, value3_str) # -c
    
    str_term_list = [term1, term2, term3] # [-ax^2, bx, -c]
    rhs_term_list = [rhs_term1, rhs_term2, rhs_term3] # [-a * x * x, + b * x, - c]
    if value2_str == &apos;0.0&apos;: # b == 0
        str_term_list = [term1, term3] # [-ax^2, -c]
        rhs_term_list = [rhs_term1, rhs_term3] # [-a * x * x, - c]
    
    rhs = &apos; &apos;.join(rhs_term_list) # -a * x * x + b * x - c
    
    rhs_form = &apos; &apos;.join(
        [&apos;{}{}&apos;.format(&apos;&apos; if str_term.startswith(&apos;-&apos;) else &apos;+&apos;, str_term) for str_term in str_term_list]
    )
    if rhs_form.startswith(&apos;+&apos;):
        rhs_form = rhs_form[1 :]
    
    return PolynomialQuestion(
