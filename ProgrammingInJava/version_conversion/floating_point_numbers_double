def text_to_latex(string):
    string_list = string.split()

    if &apos;/&apos; not in string_list:
        return string

    div_index = string_list.index(&apos;/&apos;) # Only one fraction in each expression
    
    begin_num_index = div_index - 1
    while  begin_num_index and &apos;(&apos; not in string_list[begin_num_index]:
        begin_num_index -= 1
    
    num_sub_list = string_list[begin_num_index : div_index]
    numerator = &apos; &apos;.join(num_sub_list)

    if numerator.startswith(&apos;(&apos;):
        numerator = numerator[1 :]
    if numerator.endswith(&apos;)&apos;):
        numerator = numerator[: -1]

    end_denom_index = div_index + 1
    while  end_denom_index &lt; len(string_list) and &apos;)&apos; not in string_list[end_denom_index]:
        end_denom_index += 1
    
    denom_sub_list = string_list[div_index + 1 : end_denom_index + 1]
    denominator = &apos; &apos;.join(denom_sub_list)
    
    if denominator.startswith(&apos;(&apos;):
        denominator = denominator[1 :]
    if denominator.endswith(&apos;)&apos;):
        denominator = denominator[: -1]

    replace_str = &apos; &apos;.join(string_list[begin_num_index : end_denom_index + 1])
    latex_frac = &apos;\\dfrac{ {} }{ {} }&apos;.format(numerator, denominator)
    
    return string.replace(replace_str, latex_frac)


