</zyQChoice>

<zyQChoice>
<zyQAns> Negative infinity </zyQAns>
<zyQExpl> <!--Both-->Neither operand<!--s are--> is negative<!-- values-->, so the result is positive. </zyQExpl>
</zyQChoice>
</zyQ>

<zyQ>
<zyQText> 0.0 / 0.0 </zyQText>
<zyQChoice>
<zyQAns> 0.0 </zyQAns>
